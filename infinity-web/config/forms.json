{
  "forms": {
    "iwl": {
      "title": "I Would Like",
      "mode": "email_request",
      "fields": [
        {"name": "name", "type": "text", "required": false},
        {"name": "email", "type": "email", "required": false},
        {"name": "phone", "type": "tel", "required": false},
        {"name": "message", "type": "textarea", "required": true},
        {"name": "sponsor", "type": "checkbox", "required": false}
      ]
    },
    "upload": {
      "title": "Upload a Script",
      "mode": "email_or_form",
      "fields": [
        {"name": "category", "type": "select", "required": true, "options": ["terminal", "downloads", "helpers"]},
        {"name": "purpose", "type": "text", "required": true},
        {"name": "shell", "type": "text", "required": true},
        {"name": "language", "type": "text", "required": true},
        {"name": "origin", "type": "text", "required": false},
        {"name": "note", "type": "textarea", "required": false},
        {"name": "name", "type": "text", "required": false},
        {"name": "email", "type": "email", "required": false},
        {"name": "phone", "type": "tel", "required": false},
        {"name": "address", "type": "text", "required": false},
        {"name": "personal_or_business", "type": "radio", "required": false, "options": ["personal", "business"]},
        {"name": "reason", "type": "textarea", "required": false},
        {"name": "review", "type": "textarea", "required": false}
      ]
    },
    "share": {
      "title": "Share a Script",
      "mode": "email_or_form",
      "fields": [
        {"name": "name", "type": "text", "required": false},
        {"name": "email", "type": "email", "required": false},
        {"name": "phone", "type": "tel", "required": false},
        {"name": "script_name", "type": "text", "required": true},
        {"name": "description", "type": "textarea", "required": true},
        {"name": "dependencies", "type": "textarea", "required": false}
      ]
    },
    "request": {
      "title": "Request a Script",
      "mode": "questionnaire",
      "fields": [
        {"name": "category", "type": "select", "required": true, "options": ["terminal", "downloads", "helpers"]},
        {"name": "what", "type": "textarea", "required": true},
        {"name": "why", "type": "textarea", "required": true},
        {"name": "where", "type": "text", "required": false},
        {"name": "when", "type": "text", "required": false},
        {"name": "who", "type": "text", "required": false},
        {"name": "how", "type": "textarea", "required": true}
      ]
    },
    "report": {
      "title": "Report an Incident",
      "mode": "form",
      "fields": [
        {"name": "summary", "type": "text", "required": true},
        {"name": "details", "type": "textarea", "required": true},
        {"name": "name", "type": "text", "required": false},
        {"name": "email", "type": "email", "required": false}
      ]
    },
    "review": {
      "title": "Write a Review",
      "mode": "form",
      "fields": [
        {"name": "rating", "type": "range", "required": true},
        {"name": "comment", "type": "textarea", "required": true},
        {"name": "name", "type": "text", "required": false},
        {"name": "email", "type": "email", "required": false}
      ]
    }
  }
}
