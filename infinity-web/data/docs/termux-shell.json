{
  "type": "tool",
  "group": "FILEOPS",
  "id": "termux-shell",
  "name": "termux-shell",
  "path": "assets/payloads/FILEOPS/termux-shell",
  "kindLink": "#assets/payloads/FILEOPS/termux-shell",
  "description": "Load a canonical Termux shell environment, source profile files and env.global, then hand control to bash. See #assets/payloads/FILEOPS/termux-shell.",
  "usage": "termux-shell [bash-args...]",
  "runtime": {
    "shell": "bash",
    "mode": "interactive"
  },
  "inputs": {
    "argv": [
      "optional arguments forwarded to bash"
    ]
  },
  "outputs": [
    "Exports Termux environment variables",
    "Sources .profile, .bashrc, and env.global when present",
    "Execs into a bash session"
  ],
  "dependencies": [
    "bash",
    "source $HOME/.profile",
    "source $HOME/.bashrc",
    "source $HOME/.tools/tools/env.global"
  ],
  "behavior": {
    "environment_setup": [
      "Sets PREFIX to /data/data/com.termux/files/usr",
      "Sets HOME to /data/data/com.termux/files/home",
      "Prepends PREFIX/bin to PATH",
      "Sets BASH_ENV to $HOME/.bashrc"
    ],
    "config_loading": "Sources .profile and .bashrc when present",
    "tool_loading": "Fails fast if env.global is missing",
    "handoff": "exec bash \"$@\"",
    "safety": "No file writes; environment bootstrap only"
  },
  "notes": [
    "Designed for Termux sessions that need consistent shell initialization",
    "Preserves interactive shell behavior before handing off to bash"
  ]
}
