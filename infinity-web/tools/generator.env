# =================================================================
# INFINITY SYSTEM: MANIFEST + UI FLOW SPEC
# File location: tools/generator.env
# =================================================================

[PATHS_FILESYSTEM]
PAYLOADS_ROOT_DIR=../assets/payloads
METADATA_ROOT_DIR=./cards
MANIFEST_OUTPUT_FILE=../assets/payloads/manifest.json
GLOBAL_DEFAULT_CARD_JSON=./cards/default-card.json
ICONS_MODULE_PATH=../components/icons.js

[GENERATOR_BEHAVIOR]
SCAN_MODE=directories_only
TREE_STRUCTURE=category_directory_tree
IGNORE_LIST=.DS_Store,manifest.json,.git,.htaccess
NODE_CLASSIFICATION=directory_with_matching_metadata_folder_is_file_else_directory
METADATA_FOLDER_MATCH=./cards/${relativeBase}/${folder_name}
PROP_EXTRACT_STRATEGY=strip_folder_name_prefix
JSON_UNWRAP_STRATEGY=use_named_property_if_present_else_whole_json
AUDIT_REQUIRED_FIELDS=description,author,version,images
FS_STAT_PROPERTIES=mtime
DEFAULT_CATEGORY=General
ID_GENERATION=folder_name
NAME_GENERATION=folder_name
MODIFIED_DATE_KEY=modified
LINKS_OBJECT_KEY=links
SOURCE_PATH_KEY=links.source

[METADATA_MAPPING]
THUMBNAIL_KEY=thumbnail
DOC_URL_KEY=pageUrl
DOC_TRIGGER_FILE=index.html
DOCS_PATH_TEMPLATE=tools/cards/${relativePath}/${propDir}/index.html
IMAGE_SOURCE_KEY=images
DESCRIPTION_KEY=description
AUTHOR_KEY=author
VERSION_KEY=version

[UI_RENDERING_CARDS]
CARD_CSS_CLASS=inf-card
CARD_ID_ATTR=data-script-id
EXPAND_ATTR=data-script-expand
ACTION_ATTR=data-action
TITLE_FIELD=item.name
TITLE_FALLBACK=item.title
AUTHOR_FIELD=item.author
AUTHOR_FALLBACK=item.owner
SUMMARY_FIELD=item.description
SUMMARY_FALLBACK=item.summary
SHELL_FIELD=item.shell
LANGUAGE_FIELD=item.language
CATEGORY_FIELD=item.category
DEPENDENCIES_FIELD=item.dependencies
EMPTY_TITLE=Untitled script
EMPTY_AUTHOR=Unknown author
EMPTY_DESCRIPTION=No description provided.

[INTERACTIVE_ACTIONS]
DOWNLOAD_BTN_ACTION=trigger_payload_download
SHARE_BTN_ACTION=native_share_or_route_share
REQUEST_BTN_ACTION=navigate_to_request_route
REPORT_BTN_ACTION=noop
TITLE_CLICK_ACTION=noop
DOWNLOAD_PATH_TEMPLATE=./assets/payloads/${item.path}
REQUEST_ROUTE=#request
SEARCH_ROUTE=#search?q=${query}
SEARCH_INPUT_ENTER=submit_search
SEARCH_INPUT_ESCAPE=close_search
DRAWER_TOGGLE=button_controls_hidden_state
QUICKRAIL_DEFAULT_ACTIONS=download,share,request,disclaimer

[FRONTEND_DATA_MAPPING]
UI_FIELD_AUTHOR=item.author
UI_FIELD_OWNER=item.owner
UI_FIELD_VERSION=item.version
UI_FIELD_SUMMARY=item.description
UI_FIELD_DEPENDENCIES=item.dependencies
UI_FIELD_CATEGORY=item.category
UI_FIELD_SHELL=item.shell
UI_FIELD_LANGUAGE=item.language
UI_FIELD_PATH=item.path
UI_FIELD_PAGE_URL=item.pageUrl
UI_FIELD_THUMBNAIL=item.thumbnail

[SEARCH_BEHAVIOR]
SEARCH_IMPLEMENTATION=name_only
SEARCH_SCOPE=item.name
SEARCH_MODE=case_insensitive_substring
SEARCH_ROUTE_HANDLER=../components/router.js
SEARCH_PLACEHOLDER=script names
